FORM add_dyn_field  USING    p_colname
                             p_coltext
                             p_outputlen.

gv_pos = gv_pos + 1.
gs_dyn_fcat-fieldname = p_colname .
gs_dyn_fcat-outputlen = p_outputlen.
gs_dyn_fcat-coltext   = p_coltext.
gs_dyn_fcat-col_pos   = gv_pos.

APPEND gs_dyn_fcat TO gt_dyn_fcat.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  PROCESS_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM process_data .
  DATA : lt_zpra_t_prd_pi_b   TYPE STANDARD TABLE OF zpra_t_prd_pi ,
         lt_zpra_t_prd_pi_a   TYPE STANDARD TABLE OF zpra_t_prd_pi ,
         lt_zpra_t_prd_pi_c   TYPE STANDARD TABLE OF zpra_t_prd_pi ,
         lt_zpra_t_prd_pi_t   TYPE STANDARD TABLE OF zpra_t_prd_pi .

  DATA : ls_zpra_c_prd_prof   TYPE zpra_c_prd_prof            ,
         ls_zpra_t_prd_pi     TYPE zpra_t_prd_pi              .

  DATA : lv_gjahr_index       TYPE sy-tabix                   ,
         lv_monat_index       TYPE sy-tabix                   ,
         lv_cursor            TYPE sy-tabix                   ,
         lv_qty               TYPE zpra_t_mrec_app-app_vl_qty ,
         lv_qty_b             TYPE zpra_t_mrec_app-app_vl_qty ,
         lv_qty_a             TYPE zpra_t_mrec_app-app_vl_qty ,
         lv_qty_c             TYPE zpra_t_mrec_app-app_vl_qty ,
         lv_qty_t             TYPE zpra_t_mrec_app-app_vl_qty ,
         lv_amt               TYPE p LENGTH 12 DECIMALS 9     ,
         lv_gjahr             TYPE zpra_t_mrec_app-gjahr      ,
         lv_monat             TYPE zpra_t_mrec_app-monat      ,
         lv_col1_name         TYPE lvc_fname                  ,
         lv_col2_name         TYPE lvc_fname                  ,
         lv_found             TYPE c                          ,
         lv_begin_date        TYPE sy-datum                   ,
         lv_end_date          TYPE sy-datum                   ,
         lv_gjahr_days        TYPE sy-tabix                   ,
         lv_days              TYPE sy-tabix                   ,
         lv_days_b            TYPE sy-tabix                   ,
         lv_days_a            TYPE sy-tabix                   ,
         lv_days_c            TYPE sy-tabix                   ,
         lv_days_t            TYPE sy-tabix                   ,
         lv_cntry             TYPE oiu_pr_dn-cntry_cd         ,
         lv_prd_b_start_date  TYPE sy-datum                   , "block
         lv_prd_a_start_date  TYPE sy-datum                   , "asset
         lv_prd_c_start_date  TYPE sy-datum                   , "country
         lv_prd_t_start_date  TYPE sy-datum                   , "total
         lv_gas_multiplier    TYPE zpra_t_mrec_prd-prod_vl_qty1 .

  lt_zpra_t_prd_pi_b = gt_zpra_t_prd_pi .

  lt_zpra_t_prd_pi_a = gt_zpra_t_prd_pi .
  SORT lt_zpra_t_prd_pi_a BY asset prod_start_date .
  DELETE ADJACENT DUPLICATES FROM lt_zpra_t_prd_pi_a COMPARING asset .

  lt_zpra_t_prd_pi_c = gt_zpra_t_prd_pi .
  SORT lt_zpra_t_prd_pi_a BY asset prod_start_date .
  DELETE ADJACENT DUPLICATES FROM lt_zpra_t_prd_pi_a COMPARING asset .

  lt_zpra_t_prd_pi_t = gt_zpra_t_prd_pi .
  SORT lt_zpra_t_prd_pi_t BY prod_start_date .

  APPEND INITIAL LINE TO <gfs_grand_total_data> ASSIGNING <gfs_grand_total_line> .
  LOOP AT gt_zpra_c_prd_prof INTO gs_zpra_c_prd_prof.

    CLEAR lv_prd_b_start_date .
    READ TABLE lt_zpra_t_prd_pi_b INTO ls_zpra_t_prd_pi WITH KEY asset = gs_zpra_c_prd_prof-asset
                                                                 block = gs_zpra_c_prd_prof-block BINARY SEARCH .
    IF sy-subrc IS INITIAL.
      lv_prd_b_start_date = ls_zpra_t_prd_pi-prod_start_date .
    ENDIF.

    CLEAR lv_prd_a_start_date .
    READ TABLE lt_zpra_t_prd_pi_a INTO ls_zpra_t_prd_pi WITH KEY asset = gs_zpra_c_prd_prof-asset BINARY SEARCH .
    IF sy-subrc IS INITIAL.
      lv_prd_a_start_date = ls_zpra_t_prd_pi-prod_start_date .
    ENDIF.

    CLEAR lv_prd_c_start_date .
    READ TABLE gt_oiu_pr_dn INTO gs_oiu_pr_dn WITH KEY dn_no = gs_zpra_c_prd_prof-asset BINARY SEARCH .
    IF sy-subrc IS INITIAL .
      lv_cntry = gs_oiu_pr_dn-cntry_cd .
      lv_prd_c_start_date = '99991231' .
      LOOP AT gt_oiu_pr_dn INTO gs_oiu_pr_dn WHERE cntry_cd EQ lv_cntry.
        CLEAR ls_zpra_t_prd_pi .
        READ TABLE lt_zpra_t_prd_pi_c INTO ls_zpra_t_prd_pi WITH KEY asset = gs_oiu_pr_dn-dn_no BINARY SEARCH .
        IF ls_zpra_t_prd_pi-prod_start_date IS NOT INITIAL.
          IF ls_zpra_t_prd_pi-prod_start_date LT lv_prd_c_start_date.
            lv_prd_c_start_date = ls_zpra_t_prd_pi-prod_start_date .
          ENDIF.
        ENDIF.
      ENDLOOP.
    ENDIF.

    CLEAR lv_prd_t_start_date .
    READ TABLE lt_zpra_t_prd_pi_t INTO ls_zpra_t_prd_pi INDEX 1.
    IF sy-subrc IS INITIAL.
      lv_prd_t_start_date = ls_zpra_t_prd_pi-prod_start_date .
    ENDIF.

    APPEND INITIAL LINE TO <gfs_block_data> ASSIGNING <gfs_block_line> .
    ASSIGN COMPONENT 'PRODUCT' OF STRUCTURE <gfs_block_line> TO <gfs_field> .
    IF sy-subrc IS INITIAL .
      <gfs_field> = gs_zpra_c_prd_prof-product .
      UNASSIGN <gfs_field> .
    ENDIF.
    READ TABLE gt_oiu_pr_dn INTO gs_oiu_pr_dn WITH KEY dn_no = gs_zpra_c_prd_prof-asset BINARY SEARCH .
    IF sy-subrc IS INITIAL .
      ASSIGN COMPONENT 'COUNTRY' OF STRUCTURE <gfs_block_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL .
        <gfs_field> = gs_oiu_pr_dn-cntry_cd .
        TRANSLATE <gfs_field> TO UPPER CASE .
        UNASSIGN <gfs_field> .
      ENDIF.
    ENDIF.
    ASSIGN COMPONENT 'ASSET' OF STRUCTURE <gfs_block_line> TO <gfs_field> .
    IF sy-subrc IS INITIAL .
      <gfs_field> = gs_zpra_c_prd_prof-asset .
      UNASSIGN <gfs_field> .
    ENDIF.

    ASSIGN COMPONENT 'BLOCK' OF STRUCTURE <gfs_block_line> TO <gfs_field> .
    IF sy-subrc IS INITIAL .
      <gfs_field> = gs_zpra_c_prd_prof-block .
      UNASSIGN <gfs_field> .
    ENDIF.

    IF gs_zpra_c_prd_prof-asset NE ls_zpra_c_prd_prof-asset OR
       gs_zpra_c_prd_prof-product NE ls_zpra_c_prd_prof-product .
      APPEND INITIAL LINE TO <gfs_asset_data> ASSIGNING <gfs_asset_line> .
      ASSIGN COMPONENT 'PRODUCT' OF STRUCTURE <gfs_asset_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL .
        <gfs_field> = gs_zpra_c_prd_prof-product .
        UNASSIGN <gfs_field> .
      ENDIF.
      READ TABLE gt_oiu_pr_dn INTO gs_oiu_pr_dn WITH KEY dn_no = gs_zpra_c_prd_prof-asset BINARY SEARCH .
      IF sy-subrc IS INITIAL .
        ASSIGN COMPONENT 'COUNTRY' OF STRUCTURE <gfs_asset_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL .
          <gfs_field> = gs_oiu_pr_dn-cntry_cd .
          UNASSIGN <gfs_field> .
        ENDIF.
      ENDIF.
      ASSIGN COMPONENT 'ASSET' OF STRUCTURE <gfs_asset_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL .
        <gfs_field> = gs_zpra_c_prd_prof-asset .
        UNASSIGN <gfs_field> .
      ENDIF.

      lv_col1_name = 'PRODUCT' .
      lv_col2_name = 'COUNTRY' .
      READ TABLE gt_oiu_pr_dn INTO gs_oiu_pr_dn WITH KEY dn_no = gs_zpra_c_prd_prof-asset BINARY SEARCH .
      READ TABLE <gfs_country_data> ASSIGNING <gfs_country_line> WITH KEY (lv_col1_name) = gs_zpra_c_prd_prof-product
                                                                          (lv_col2_name) = gs_oiu_pr_dn-cntry_cd .
      IF sy-subrc IS NOT INITIAL.
        APPEND INITIAL LINE TO <gfs_country_data> ASSIGNING <gfs_country_line> .
        ASSIGN COMPONENT 'PRODUCT' OF STRUCTURE <gfs_country_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL .
          <gfs_field> = gs_zpra_c_prd_prof-product .
          UNASSIGN <gfs_field> .
        ENDIF.
        ASSIGN COMPONENT 'COUNTRY' OF STRUCTURE <gfs_country_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL .
          <gfs_field> = gs_oiu_pr_dn-cntry_cd  .
          UNASSIGN <gfs_field> .
        ENDIF.
      ENDIF.
    ENDIF.

    IF gs_zpra_c_prd_prof-product NE ls_zpra_c_prd_prof-product.
      APPEND INITIAL LINE TO <gfs_total_data> ASSIGNING <gfs_total_line> .
      ASSIGN COMPONENT 'PRODUCT' OF STRUCTURE <gfs_total_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL .
        <gfs_field> = gs_zpra_c_prd_prof-product .
        UNASSIGN <gfs_field> .
      ENDIF.

    ENDIF.
    CLEAR lv_gjahr .
    DO 5 TIMES.
      lv_gjahr_index = sy-index .
      lv_gjahr = gv_gjahr_from + lv_gjahr_index - 1 .
      PERFORM get_gjahr_days USING lv_gjahr CHANGING lv_gjahr_days .
      CLEAR lv_monat .
      DO 12 TIMES.
        CLEAR : lv_qty   ,
                lv_qty_b  ,
                lv_qty_a  ,
                lv_qty_c  ,
                lv_qty_t  ,
                lv_found .
        lv_monat = lv_monat + 1 .
* First Search from FIRM Data..
        CLEAR gs_zpra_t_mrec_app.
        READ TABLE gt_zpra_t_mrec_app INTO gs_zpra_t_mrec_app WITH KEY gjahr   = lv_gjahr
                                                                       monat   = lv_monat
                                                                       asset   = gs_zpra_c_prd_prof-asset
                                                                       block   = gs_zpra_c_prd_prof-block
                                                                       product = gs_zpra_c_prd_prof-product BINARY SEARCH .
        IF sy-subrc IS INITIAL.
          lv_found = 'X' .
          lv_qty   = gs_zpra_t_mrec_app-app_vl_qty .
          lv_qty   = lv_qty * 1000000 .
        ENDIF.
*        IF lv_found IS INITIAL.
* Now search Monthly reconciled data
*          CLEAR gs_zpra_t_mrec_prd.
*          READ TABLE gt_zpra_t_mrec_prd INTO gs_zpra_t_mrec_prd WITH KEY gjahr   = lv_gjahr
*                                                                         monat   = lv_monat
*                                                                         asset   = gs_zpra_c_prd_prof-asset
*                                                                         block   = gs_zpra_c_prd_prof-block
*                                                                         product = gs_zpra_c_prd_prof-product BINARY SEARCH .
*          IF sy-subrc IS INITIAL.
*            lv_found = 'X' .
*            lv_qty   = gs_zpra_t_mrec_prd-prod_vl_qty1 .
*          ENDIF.
*        ENDIF.
        IF lv_found IS INITIAL.
* Now search daily reconciled data
          PERFORM get_month_begin_end_dates USING lv_gjahr lv_monat CHANGING lv_begin_date lv_end_date .
          CLEAR lv_cursor .
          READ TABLE gt_zpra_t_dly_rprd TRANSPORTING NO FIELDS WITH KEY product         = gs_zpra_c_prd_prof-product
                                                                        asset           = gs_zpra_c_prd_prof-asset
                                                                        block           = gs_zpra_c_prd_prof-block
                                                                        production_date = lv_begin_date  BINARY SEARCH .
          IF sy-subrc IS INITIAL.
            lv_cursor = sy-tabix .
          ENDIF.
          IF lv_cursor IS INITIAL AND lv_prd_b_start_date LE lv_end_date .
            READ TABLE gt_zpra_t_dly_rprd TRANSPORTING NO FIELDS WITH KEY product         = gs_zpra_c_prd_prof-product
                                                                          asset           = gs_zpra_c_prd_prof-asset
                                                                          block           = gs_zpra_c_prd_prof-block .
            IF sy-subrc IS INITIAL.
              lv_cursor = sy-tabix .
            ENDIF.

          ENDIF.
          IF lv_cursor IS NOT INITIAL.
            LOOP AT gt_zpra_t_dly_rprd INTO gs_zpra_t_dly_rprd FROM lv_cursor .
               IF gs_zpra_t_dly_rprd-production_date LT lv_begin_date.
                 CONTINUE .
               ENDIF.
              IF gs_zpra_t_dly_rprd-production_date GT lv_end_date OR
                 gs_zpra_t_dly_rprd-product         NE gs_zpra_c_prd_prof-product OR
                 gs_zpra_t_dly_rprd-asset           NE gs_zpra_c_prd_prof-asset   OR
                 gs_zpra_t_dly_rprd-block           NE gs_zpra_c_prd_prof-block .
                EXIT.
              ENDIF.
              PERFORM convert_rprd_units USING gs_zpra_t_dly_rprd .
              lv_qty = lv_qty + gs_zpra_t_dly_Rprd-jv_prd_vl_qty1 .
              lv_found = 'X' .
            ENDLOOP.
          ENDIF.
        ENDIF.
        IF lv_found IS INITIAL.
* Now search daily unreconciled data
          PERFORM get_month_begin_end_dates USING lv_gjahr lv_monat CHANGING lv_begin_date lv_end_date .
          CLEAR lv_cursor .
          READ TABLE gt_zpra_t_dly_prd TRANSPORTING NO FIELDS WITH KEY product         = gs_zpra_c_prd_prof-product
                                                                       asset           = gs_zpra_c_prd_prof-asset
                                                                       block           = gs_zpra_c_prd_prof-block
                                                                       production_date = lv_begin_date  BINARY SEARCH .
          IF sy-subrc IS INITIAL.
            lv_cursor = sy-tabix .
          ENDIF.
          IF lv_cursor IS INITIAL.
            READ TABLE gt_zpra_t_dly_prd TRANSPORTING NO FIELDS WITH KEY product         = gs_zpra_c_prd_prof-product
                                                                         asset           = gs_zpra_c_prd_prof-asset
                                                                         block           = gs_zpra_c_prd_prof-block .
            IF sy-subrc IS INITIAL.
              lv_cursor = sy-tabix .
            ENDIF.
          ENDIF.
          IF lv_cursor IS NOT INITIAL.
            LOOP AT gt_zpra_t_dly_prd INTO gs_zpra_t_dly_prd FROM lv_cursor .
               IF gs_zpra_t_dly_prd-production_date LT lv_begin_date.
                 CONTINUE .
               ENDIF.
              IF gs_zpra_t_dly_prd-production_date GT lv_end_date OR
                 gs_zpra_t_dly_prd-product         NE gs_zpra_c_prd_prof-product OR
                 gs_zpra_t_dly_prd-asset           NE gs_zpra_c_prd_prof-asset   OR
                 gs_zpra_t_dly_prd-block           NE gs_zpra_c_prd_prof-block .
                EXIT.
              ENDIF.
              PERFORM convert_non_gas_units USING gs_zpra_t_dly_prd.
              PERFORM convert_to_ovl        USING gs_zpra_t_dly_prd.
              lv_qty = lv_qty + gs_zpra_t_dly_prd-prod_vl_qty1 .
            ENDLOOP.
          ENDIF.
        ENDIF.

    lv_qty_b = lv_qty .
    lv_qty_a = lv_qty .
    lv_qty_c = lv_qty .
    lv_qty_t = lv_qty .

    IF p_bbd IS NOT INITIAL OR
       p_tmd IS NOT INITIAL OR
       p_bmd IS NOT INITIAL.
     lv_days   = lv_gjahr_days .
     lv_days_b = lv_gjahr_days .
     lv_days_a = lv_gjahr_days .
     lv_days_c = lv_gjahr_days .
     lv_days_t = lv_gjahr_days .

     IF lv_prd_b_start_date GT gv_start_date.
       lv_days_b = gv_end_date - lv_prd_b_start_date + 1 .
     ENDIF.
     IF lv_prd_a_start_date GT gv_start_date.
       lv_days_a = gv_end_date - lv_prd_a_start_date + 1 .
     ENDIF.
     IF lv_prd_c_start_date GT gv_start_date.
       lv_days_c = gv_end_date - lv_prd_c_start_date + 1 .
     ENDIF.
     IF lv_prd_t_start_date GT gv_start_date.
       lv_days_t = gv_end_date - lv_prd_t_start_date + 1 .
     ENDIF.
     lv_qty    = lv_qty    / lv_days .
     lv_qty_b  = lv_qty_b  / lv_days_b .
     lv_qty_a  = lv_qty_a  / lv_days_a .
     lv_qty_c  = lv_qty_c  / lv_days_c .
     lv_qty_t  = lv_qty_t  / lv_days_t .
    ENDIF.

    IF p_mb IS NOT INITIAL.
     lv_qty    = lv_qty    / 1000000 .
     lv_qty_b  = lv_qty_b  / 1000000 .
     lv_qty_a  = lv_qty_a  / 1000000 .
     lv_qty_c  = lv_qty_c  / 1000000 .
     lv_qty_t  = lv_qty_t  / 1000000 .
    ENDIF.
    IF p_bmd IS NOT INITIAL AND gs_zpra_c_prd_prof-product EQ c_prod_gas.
     lv_qty    = lv_qty    / 6290 .
     lv_qty_b  = lv_qty_b  / 6290 .
     lv_qty_a  = lv_qty_a  / 6290 .
     lv_qty_c  = lv_qty_c  / 6290 .
     lv_qty_t  = lv_qty_t  / 6290 .
    ENDIF.

        lv_col1_name = lv_gjahr .
        SHIFT lv_col1_name LEFT DELETING LEADING space .
        ASSIGN COMPONENT lv_col1_name OF STRUCTURE <gfs_block_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL.
          <gfs_field> = <gfs_field> + lv_qty_b .
          lv_amt = <gfs_field> .
          IF lv_amt LT 0.
            <gfs_field> = <gfs_field> * -1 .
            SHIFT <gfs_field> LEFT DELETING LEADING SPACE .
            CONCATENATE '-' <gfs_field> INTO <gfs_field> .
          ENDIF.
          UNASSIGN <gfs_field> .
        ENDIF.

        ASSIGN COMPONENT lv_col1_name OF STRUCTURE <gfs_asset_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL.
          <gfs_field> = <gfs_field> + lv_qty_a .
          lv_amt = <gfs_field> .
          IF lv_amt LT 0.
            <gfs_field> = <gfs_field> * -1 .
            SHIFT <gfs_field> LEFT DELETING LEADING SPACE .
            CONCATENATE '-' <gfs_field> INTO <gfs_field> .
          ENDIF.
          UNASSIGN <gfs_field> .
        ENDIF.

        ASSIGN COMPONENT lv_col1_name OF STRUCTURE <gfs_country_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL.
          <gfs_field> = <gfs_field> + lv_qty_c .
          lv_amt = <gfs_field> .
          IF lv_amt LT 0.
            <gfs_field> = <gfs_field> * -1 .
            SHIFT <gfs_field> LEFT DELETING LEADING SPACE .
            CONCATENATE '-' <gfs_field> INTO <gfs_field> .
          ENDIF.
          UNASSIGN <gfs_field> .
        ENDIF.

        ASSIGN COMPONENT lv_col1_name OF STRUCTURE <gfs_total_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL.
          <gfs_field> = <gfs_field> + lv_qty_t .
          lv_amt = <gfs_field> .
          IF lv_amt LT 0.
            <gfs_field> = <gfs_field> * -1 .
            SHIFT <gfs_field> LEFT DELETING LEADING SPACE .
            CONCATENATE '-' <gfs_field> INTO <gfs_field> .
          ENDIF.
          UNASSIGN <gfs_field> .
        ENDIF.

        IF gs_zpra_c_prd_prof-product = c_prod_gas AND p_bmd IS NOT INITIAL.
          lv_gas_multiplier = 6290 .
        ELSE .
          lv_gas_multiplier = 1 .
        ENDIF.

        ASSIGN COMPONENT lv_col1_name OF STRUCTURE <gfs_grand_total_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL.
          <gfs_field> = <gfs_field> + lv_qty_t * lv_gas_multiplier.
          lv_amt = <gfs_field> .
          IF lv_amt LT 0.
            <gfs_field> = <gfs_field> * -1 .
            SHIFT <gfs_field> LEFT DELETING LEADING SPACE .
            CONCATENATE '-' <gfs_field> INTO <gfs_field> .
          ENDIF.
          UNASSIGN <gfs_field> .
        ENDIF.
      ENDDO.
    ENDDO.
    ls_zpra_c_prd_prof = gs_zpra_c_prd_prof .
  ENDLOOP.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GET_MONTH_BEGIN_END_DATES
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LV_GJAHR  text
*      -->P_LV_MONAT  text
*      <--P_LV_BEGIN_DATE  text
*      <--P_LV_END_DATE  text
*----------------------------------------------------------------------*
FORM get_month_begin_end_dates  USING    p_gjahr
                                         p_monat
                                CHANGING p_begin_date
                                         p_end_date.

   DATA : lv_poper TYPE t009b-poper .
   lv_poper = p_monat .

   CALL FUNCTION 'FIRST_DAY_IN_PERIOD_GET'
    EXPORTING
     i_gjahr              = p_gjahr
*   I_MONMIT             = 00
     i_periv              = gv_periv
     i_poper              = lv_poper
    IMPORTING
     e_date               =  p_begin_date
    EXCEPTIONS
     input_false          = 1
     t009_notfound        = 2
     t009b_notfound       = 3
     OTHERS               = 4
          .
   IF sy-subrc <> 0.
    MESSAGE 'Internal Error' TYPE 'E' .
   ENDIF.

   CALL FUNCTION 'LAST_DAY_IN_PERIOD_GET'
    EXPORTING
     i_gjahr              = p_gjahr
*    I_MONMIT             = 00
     i_periv              = gv_periv
     i_poper              = lv_poper
    IMPORTING
     e_date               = p_end_date
    EXCEPTIONS
     input_false          = 1
     t009_notfound        = 2
     t009b_notfound       = 3
     OTHERS               = 4
           .
   IF sy-subrc <> 0.
    MESSAGE 'Internal Error' TYPE 'E' .
   ENDIF.

ENDFORM.
