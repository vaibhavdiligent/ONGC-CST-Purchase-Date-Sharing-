*&---------------------------------------------------------------------*
*&      Form  DISPLAY_TABLE_HEADING
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM display_table_heading .

  DATA : lv_gjahr      TYPE zpra_t_mrec_prd-gjahr ,
         lv_gjahr_next TYPE zpra_t_mrec_prd-gjahr ,
         lv_index TYPE sy-tabix              .

  gv_row = gv_row + 1 .
  gv_s_row = gv_row .
  gv_s_col = gv_hier_level + 1 .
  gv_e_row = gv_s_row .
  gv_e_col = gv_s_col + gv_hier_level - 1.

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  CALL METHOD OF go_range 'Merge'  .
  gv_txt = 'Fiscal Year' .
  PERFORM set_range USING gv_txt 0.

  lv_gjahr = gv_gjahr_from .
  DO 5 TIMES.
    CLEAR gv_txt .
    lv_gjahr_next = lv_gjahr + 1 .
    CONCATENATE lv_gjahr '-' lv_gjahr_next+2(2) INTO gv_txt .

    gv_s_col = gv_e_col + 1 .
    gv_e_col = gv_s_col .
    PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
    PERFORM set_range USING gv_txt 0.

    lv_gjahr = lv_gjahr + 1 .
  ENDDO.

  gv_s_col = gv_hier_level + 1 .
  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_output_columns  .
  PERFORM set_all_borders_range .

  PERFORM select_range USING gv_s_row 1 gv_e_row gv_output_columns  .
  PERFORM set_thick_border USING 1 1 1 1 .
  PERFORM set_range_interior USING gv_header_colour_table .

ENDFORM.

*&---------------------------------------------------------------------*
*&      Form  SELECT_RANGE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_GV_ROW  text
*      -->P_1      text
*      -->P_GV_SEC1_LINES  text
*      -->P_30     text
*----------------------------------------------------------------------*
FORM select_range  USING    p_s_row
                            p_s_col
                            p_e_row
                            p_e_col .

  CALL METHOD OF go_excel 'Cells' = go_cell_from
   EXPORTING
   #1 = p_s_row
   #2 = p_s_col .

  CALL METHOD OF go_excel 'Cells' = go_cell_to
   EXPORTING
   #1 = p_e_row
   #2 = p_e_col .

  CALL METHOD OF go_excel 'Range' = go_range
    EXPORTING
    #1 = go_cell_from
    #2 = go_cell_to.

  CALL METHOD OF go_range 'Select' .

ENDFORM.
FORM set_range  USING    p_cell_value
                        p_wraptext  .
  SET PROPERTY OF go_range 'Value' = p_cell_value .
  SET PROPERTY OF go_range 'WrapText' = p_wraptext .
ENDFORM.
