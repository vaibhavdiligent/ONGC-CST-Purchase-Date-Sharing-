 GET PROPERTY OF go_worksheet 'Shapes' = lo_shapes.

 CALL METHOD OF lo_shapes 'AddPicture'
 EXPORTING
 #1 = gv_image_name "image file name on presentation server
 #2 = '1'
 #3 = '1'
 #4 = 1      "left
 #5 = 1      "top
 #6 = 195    "right
 #7 = 45.    "bottom

 gv_row = gv_row + 2 .
