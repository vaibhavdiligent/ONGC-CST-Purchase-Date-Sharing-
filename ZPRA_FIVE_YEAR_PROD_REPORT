*      -->P_GS_ZPRA_T_DLY_PRD  text
*----------------------------------------------------------------------*
FORM convert_to_ovl  USING    p_zpra_t_dly_prd TYPE zpra_t_dly_prd.
  IF p_c_ovl IS NOT INITIAL.
    LOOP AT gt_zpra_t_prd_pi INTO gs_zpra_t_prd_pi WHERE asset EQ p_zpra_t_dly_prd-asset
                                                     AND block EQ p_zpra_t_dly_prd-block
                                                     AND vld_frm LE p_zpra_t_dly_prd-production_date
                                                     AND vld_to  GE p_zpra_t_dly_prd-production_date .
      p_zpra_t_dly_prd-prod_vl_qty1 = p_zpra_t_dly_prd-prod_vl_qty1 * gs_zpra_t_prd_pi-pi  / 100 .
      EXIT .
    ENDLOOP.
  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  CHECK_GJAHR
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM check_gjahr .
  DATA : lv_gjahr  TYPE zpra_t_mrec_prd-gjahr ,
         lv_poper  TYPE t009b-poper           .
 SELECT SINGLE periv
          FROM t001
          INTO gv_periv
         WHERE bukrs EQ 'OVL' .

  CALL FUNCTION 'DATE_TO_PERIOD_CONVERT'
       EXPORTING
            i_date         = sy-datum
          " I_MONMIT       = 00
            i_periv        = gv_periv
       IMPORTING
            e_buper        = lv_poper
            e_gjahr        = lv_gjahr
       EXCEPTIONS
            input_false    = 01
            t009_notfound  = 02
            t009b_notfound = 03.

  IF sy-subrc <> 0.
    MESSAGE 'Error getting Period' TYPE 'E' .
  ENDIF.
  IF lv_gjahr EQ p_gjahr.
    MESSAGE 'Current Fiscal Year can not be selected' TYPE 'E' .
  ELSEIF p_gjahr GT lv_gjahr.
    MESSAGE 'Future Fiscal Year can not be selected' TYPE 'E' .
  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  FINALIZE_EXCEL
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM finalize_excel .
 DATA: lv_uzeit_ext  TYPE char8       ,
       lv_datum_ext  TYPE char10      .

 PERFORM format_excel .

 PERFORM select_range USING 1 1 1 1.

 CONCATENATE sy-uzeit(2) '-' sy-uzeit+2(2) '-' sy-uzeit+4(2) INTO lv_uzeit_ext .
 CONCATENATE sy-datum+6(2) '-' sy-datum+4(2) '-' sy-datum(4) INTO lv_datum_ext .

 SET PROPERTY OF go_excel 'VISIBLE' = 1 .

 CONCATENATE p_fname '\5YRS -' 'On -' lv_datum_ext '-' lv_uzeit_ext '.PDF' INTO p_fname .
 CALL METHOD OF go_workbook 'ExportAsFixedFormat'
   EXPORTING
     #1 = 0
     #2 = p_fname
     #3 = 0
     #4 = 1 .
 MESSAGE 'Report downloaded sucessfully' TYPE 'S' .
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  SET_ALIGNMENT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM set_alignment .

  PERFORM select_range USING 1 1 gv_row gv_output_columns  .
  PERFORM set_range_formatting USING  0 'C' 'C' .

  gv_s_col = gv_hier_level + 1 .
  gv_e_col = gv_s_col + gv_hier_level - 1 .

  PERFORM select_range USING 1 gv_s_col gv_row gv_e_col.
  PERFORM set_range_formatting USING  0 'L' 'C' .

ENDFORM.
FORM set_range_formatting USING p_wraptext
                                p_horizontal
                                p_vertical .
  SET PROPERTY OF go_range 'WrapText' = p_wraptext .
  IF p_horizontal EQ 'C'.
   SET PROPERTY OF go_range 'HorizontalAlignment' =  -4108 .
  ELSEIF  p_horizontal EQ 'L'.
   SET PROPERTY OF go_range 'HorizontalAlignment' =  -4131 .
  ELSEIF  p_horizontal EQ 'R'.
   SET PROPERTY OF go_range 'HorizontalAlignment' =  -4152 .
  ENDIF.
  IF p_vertical EQ 'C' .
    SET PROPERTY OF go_range 'VerticalAlignment' = -4108 .
  ELSEIF p_vertical EQ 'T' .
    SET PROPERTY OF go_range 'VerticalAlignment' = -4160 .
  ELSEIF p_vertical EQ 'B' .
    SET PROPERTY OF go_range 'VerticalAlignment' = -4107 .
  ENDIF.
ENDFORM .
*&---------------------------------------------------------------------*
*&      Form  SET_NUMBER_FORMAT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM set_number_format .
  DATA : lv_number_format TYPE char10   .

  PERFORM get_full_number_format CHANGING lv_number_format .

  gv_s_col = 2 * gv_hier_level + 1 .
  PERFORM select_range USING 1 gv_s_col gv_row gv_output_columns  .
  PERFORM set_numberformat USING lv_number_format .

  IF p_bmd IS NOT INITIAL.
    PERFORM select_range USING gv_gas_start_row gv_s_col gv_gas_end_row gv_output_columns  .
    PERFORM set_numberformat USING '0.000' .
  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GET_FULL_NUMBER_FORMAT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      <--P_NUMBER_FORMAT  text
*----------------------------------------------------------------------*
FORM get_full_number_format  CHANGING p_number_format.

p_number_format = '0.000' .

IF p_bb  IS NOT INITIAL OR
   p_bbd IS NOT INITIAL OR
   p_bmd IS NOT INITIAL .
  p_number_format = '0' .
ENDIF.
ENDFORM.
FORM set_numberformat USING p_format.
  SET PROPERTY OF go_range 'NumberFormat' = p_format .
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GET_YEAR_TEXT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM get_year_text .
  DATA: lv_next_year TYPE gjahr.

  IF p_gjahr IS NOT INITIAL.
    CLEAR: lv_next_year.
    lv_next_year = p_gjahr + 1.
    CONCATENATE: 'Fiscal Year'(051) p_gjahr  'means FY'(052)  p_gjahr '-' lv_next_year+2(2)
    INTO gv_year
    SEPARATED BY space.
  ELSE.
    CLEAR: gv_year.
  ENDIF.
ENDFORM.
