*&---------------------------------------------------------------------*
*&      Form  CONVERT_NON_GAS_UNITS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_GS_ZPRA_T_DLY_PRD  text
*----------------------------------------------------------------------*
FORM convert_non_gas_units  USING    p_zpra_t_dly_prd TYPE zpra_t_dly_prd.
  DATA : lv_poper           TYPE t009b-poper ,
         lv_monat           TYPE zpra_t_mrec_prd-monat ,
         lv_gjahr           TYPE zpra_t_mrec_prd-gjahr .
  DATA : lv_cf TYPE zpra_t_tar_cf-conv_factor .

  CHECK p_zpra_t_dly_prd-product NE c_prod_gas .

  CALL FUNCTION 'DATE_TO_PERIOD_CONVERT'
       EXPORTING
            i_date         = p_zpra_t_dly_prd-production_date
          " I_MONMIT       = 00
            i_periv        = gv_periv
       IMPORTING
            e_buper        = lv_poper
            e_gjahr        = lv_gjahr
       EXCEPTIONS
            input_false    = 01
            t009_notfound  = 02
            t009b_notfound = 03.
  lv_monat = lv_poper+1(2) .

  CLEAR gs_zpra_t_mrec_prd .
  LOOP AT gt_zpra_t_mrec_prd INTO gs_zpra_t_mrec_prd WHERE product      EQ p_zpra_t_dly_prd-product
                                                       AND asset        EQ p_zpra_t_dly_prd-asset
                                                       AND block        EQ p_zpra_t_dly_prd-block
                                                       AND prd_vl_type  EQ p_zpra_t_dly_prd-prd_vl_type .
    IF  gs_zpra_t_mrec_prd-gjahr LT lv_gjahr OR
       ( gs_zpra_t_mrec_prd-gjahr EQ lv_gjahr AND
         gs_zpra_t_mrec_prd-monat LE lv_monat  ) .
      EXIT .
    ENDIF.
  ENDLOOP .
  CASE abap_true.
    WHEN p_bb OR p_bbd OR p_bmd.
    WHEN p_tm Or p_tmd .
     IF gs_zpra_t_mrec_prd-prod_vl_qty1 IS NOT INITIAL.
*      p_zpra_t_dly_prd-prod_vl_qty1 = p_zpra_t_dly_prd-prod_vl_qty1 / gs_zpra_t_mrec_prd-prod_vl_qty1 * gs_zpra_t_mrec_prd-prod_vl_qty2.
      lv_cf   = gs_zpra_t_mrec_prd-prod_vl_qty1 / gs_zpra_t_mrec_prd-prod_vl_qty2.
     ELSE.
       PERFORM get_cf_from_date USING  p_zpra_t_dly_prd-production_date
                                       p_zpra_t_dly_prd-product
                                       p_zpra_t_dly_prd-asset
                                       p_zpra_t_dly_prd-block
                              CHANGING lv_cf.
     ENDIF.
     IF lv_cf IS NOT INITIAL.
        p_zpra_t_dly_prd-prod_vl_qty1 = p_zpra_t_dly_prd-prod_vl_qty1 / lv_cf .
     ENDIF.
    WHEN p_mb .
     IF gs_zpra_t_mrec_prd-prod_vl_qty1 IS NOT INITIAL.
*      p_zpra_t_dly_prd-prod_vl_qty1 = p_zpra_t_dly_prd-prod_vl_qty1 / gs_zpra_t_mrec_prd-prod_vl_qty1 * gs_zpra_t_mrec_prd-prod_vl_qty2 .
*      p_zpra_t_dly_prd-prod_vl_qty1 = p_zpra_t_dly_prd-prod_vl_qty1 / 1000000 .
      lv_cf   = gs_zpra_t_mrec_prd-prod_vl_qty1 / gs_zpra_t_mrec_prd-prod_vl_qty2.
     ELSE.
       PERFORM get_cf_from_date USING  p_zpra_t_dly_prd-production_date
                                       p_zpra_t_dly_prd-product
                                       p_zpra_t_dly_prd-asset
                                       p_zpra_t_dly_prd-block
                              CHANGING lv_cf.
     ENDIF.
     IF lv_cf IS NOT INITIAL.
        p_zpra_t_dly_prd-prod_vl_qty1 = p_zpra_t_dly_prd-prod_vl_qty1 / lv_cf .
     ENDIF.
    WHEN OTHERS .
  ENDCASE .
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GET_PRODUCT_UOM
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_P_PRODUCT  text
*      <--P_LV_UNIT  text
*----------------------------------------------------------------------*
FORM get_product_uom  USING    p_product
                      CHANGING p_unit.

  CASE p_product.
    WHEN c_prod_oil.
      CASE abap_true.
        WHEN p_bb.
          p_unit   = 'BBL' .
        WHEN p_bbd.
          p_unit   = 'BOPD' .
        WHEN p_tm.
          p_unit   = 'Tons' .
        WHEN p_tmd.
          p_unit   = 'TPD' .
        WHEN p_mb.
          p_unit   = 'MMT' .
        WHEN p_bmd.
          p_unit   = 'BOPD' .
        WHEN OTHERS.
      ENDCASE.
    WHEN c_prod_con.
      CASE abap_true.
        WHEN p_bb.
          p_unit   = 'BBL' .
        WHEN p_bbd.
          p_unit   = 'BCPD' .
        WHEN p_tm.
          p_unit   = 'Tons' .
        WHEN p_tmd.
          p_unit   = 'TPD' .
        WHEN p_mb.
          p_unit   = 'MMT' .
        WHEN p_bmd.
          p_unit   = 'BCPD' .
        WHEN OTHERS.
      ENDCASE.
    WHEN c_prod_lng.
      CASE abap_true.
        WHEN p_bb.
          p_unit   = 'BOE' .
        WHEN p_bbd.
          p_unit   = 'BOEPD' .
        WHEN p_tm.
          p_unit   = 'Tons' .
        WHEN p_tmd.
          p_unit   = 'TPD' .
        WHEN p_mb.
          p_unit   = 'MMT' .
        WHEN p_bmd.
          p_unit   = 'MMSCMD' .
        WHEN OTHERS.
      ENDCASE.
    WHEN c_prod_gas.
      CASE abap_true.
        WHEN p_bb.
          p_unit   = 'BOE' .
        WHEN p_bbd.
          p_unit   = 'BOEPD' .
        WHEN p_tm.
          p_unit   = 'MSCM' .
        WHEN p_tmd.
          p_unit   = 'MSCMD' .
        WHEN p_mb.
          p_unit   = 'BCM' .
        WHEN p_bmd.
          p_unit   = 'MMSCMD' .
        WHEN OTHERS.
      ENDCASE.
    WHEN OTHERS.
  ENDCASE.

ENDFORM.
