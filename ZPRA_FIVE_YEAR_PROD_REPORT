*&---------------------------------------------------------------------*
*&      Form  DISPLAY_PRODUCT_HEADER
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_P_PRODUCT_DESC  text
*----------------------------------------------------------------------*
FORM display_product_header  USING  p_product
                                    p_product_desc.
  DATA : lv_cols TYPE sy-tabix ,
         lv_unit   TYPE char50 .

  gv_row = gv_row + 1 .
  gv_s_row = gv_row .
  gv_e_row = gv_row .
  gv_s_col = 1 .
  gv_e_col = gv_hier_level .

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  CALL METHOD OF go_range 'Merge'  .
  PERFORM set_range USING 'Product'  0.

  gv_s_col = gv_e_col + 1 .

  gv_e_col = gv_s_col + gv_hier_level - 1 .

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  CALL METHOD OF go_range 'Merge'  .
  PERFORM set_range USING p_product_desc  0.

  gv_s_col = gv_e_col + 1 .
  gv_e_col = gv_e_col + 5 .
  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  CALL METHOD OF go_range 'Merge'  .
  PERFORM get_product_uom USING p_product CHANGING lv_unit .
  CLEAR gv_txt .
  IF p_c_jv IS NOT INITIAL.
    gv_txt = '( JV Share )' .
  ELSE.
    gv_txt = '( OVL Share )' .
  ENDIF.
  CONCATENATE p_product_desc 'Net Production in' lv_unit gv_txt INTO gv_txt SEPARATED BY space .
  PERFORM set_range USING gv_txt  0.


  PERFORM select_range USING gv_s_row 1 gv_e_row gv_output_columns  .
  PERFORM set_all_borders_range .
  PERFORM set_thick_border USING 1 1 1 1 .
  CASE p_product.
    WHEN c_prod_oil.
      PERFORM set_range_interior USING gv_header_oil_colour.
    WHEN c_prod_con.
      PERFORM set_range_interior USING gv_header_cond_colour.
    WHEN c_prod_lng.
      PERFORM set_range_interior USING gv_header_lng_colour.
    WHEN c_prod_gas.
      PERFORM set_range_interior USING gv_header_gas_colour.
    WHEN OTHERS.
  ENDCASE.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  DISPLAY_PRODUCT_LINES
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_P_PRODUCT  text
*----------------------------------------------------------------------*
FORM display_product_lines  USING    p_product.
  DATA : lv_lines     TYPE sy-tabix ,
         lv_col       TYPE sy-tabix ,
         lv_start_row TYPE sy-tabix .

  PERFORM prepare_lines_paste_data USING p_product .

  DESCRIBE TABLE gt_paste LINES lv_lines .
  CHECK lv_lines IS NOT INITIAL .

  gv_row = gv_row + 1 .
  lv_start_row = gv_row .

  IF p_product EQ c_prod_gas.
    gv_gas_start_row = gv_row .
  ENDIF.
  gv_s_row = gv_row .
  gv_s_col = 1 .
  gv_e_row = gv_s_row + lv_lines - 1 .
  gv_e_col = gv_s_col + gv_output_columns - 1.

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  PERFORM paste_data .

  gv_s_col = 1 .
  gv_e_col = gv_hier_level .

  PERFORM select_range USING gv_s_row 1 gv_e_row gv_e_col  .
  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '12'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .
  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '10'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .

  lv_col = gv_output_columns - 5 .
  PERFORM select_range USING gv_s_row 2 gv_e_row lv_col  .
  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '12'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .

  lv_col = lv_col + 1 .
  PERFORM select_range USING gv_s_row lv_col gv_e_row gv_output_columns  .
  PERFORM set_all_borders_range .


  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_output_columns  .
  PERFORM set_thick_border USING 1 1 1 1 .
  gv_row = gv_e_row .

  LOOP AT gt_country_lines INTO gs_country_lines.
    gv_s_row = lv_start_row + gs_country_lines-line_no - 1.
    gv_e_row = gv_s_row .
    PERFORM select_range USING gv_s_row 1 gv_e_row gv_output_columns  .
    PERFORM set_range_font  USING 11 1 .
  ENDLOOP.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  PREPARE_LINES_PASTE_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_PRODUCT  text
*----------------------------------------------------------------------*
FORM prepare_lines_paste_data  USING    p_product.
  DATA : lv_index1     TYPE sy-tabix  ,
         lv_cond_name1 TYPE char100   ,
         lv_cond_name2 TYPE char100   ,
         lv_cond_name3 TYPE char100   ,
         lv_col_value1 TYPE char30    ,
         lv_sr_no      TYPE char20    ,
         lv_sr_no2     TYPE char20    ,
         lv_sr_no3     TYPE char20    ,
         lv_product    TYPE char50    ,
         lv_country    TYPE char50    ,
         lv_asset      TYPE char50    ,
         lv_lines      TYPE sy-tabix  .

  FIELD-SYMBOLS : <lfs_country> ,
                  <lfs_asset>   .

  CLEAR   gs_paste.
  REFRESH gt_paste .
  REFRESH gt_country_lines .

* Country Level Data..
  CONCATENATE '''' p_product '''' INTO lv_product .
  CONCATENATE 'PRODUCT EQ' lv_product INTO lv_cond_name1 SEPARATED BY space .
  LOOP AT <gfs_country_data> ASSIGNING <gfs_country_line> WHERE (lv_cond_name1) .
    CLEAR gs_paste .
    lv_sr_no = lv_sr_no + 1 .
    SHIFT lv_sr_no LEFT DELETING LEADING space .
    lv_col_value1 = lv_sr_no .
    gs_paste = lv_col_value1 .
    IF gv_hier_level GT 1.
      CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab INTO gs_paste .
    ENDIF.
    IF gv_hier_level GT 2.
      CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab INTO gs_paste .
    ENDIF.
    DO .

     lv_index1 = sy-index .
     ASSIGN COMPONENT lv_index1 OF STRUCTURE <gfs_country_line> TO <gfs_field> .
     IF sy-subrc IS INITIAL.
       IF lv_index1 EQ 1 .
         CONTINUE .
       ELSEIF lv_index1 EQ 2.
         READ TABLE gt_t005t INTO gs_t005t WITH KEY land1 = <gfs_field> BINARY SEARCH .
         IF sy-subrc IS INITIAL.
           lv_col_value1 = gs_t005t-landx .
           TRANSLATE lv_col_value1 TO UPPER CASE .
         ENDIF.
       ELSEIF lv_index1 EQ 3 .
         IF gv_hier_level GT 1.
           lv_col_value1 = '' .
         ELSE .
           CONTINUE .
         ENDIF.
       ELSEIF lv_index1 EQ 4 .
         IF gv_hier_level GT 2.
           lv_col_value1 = '' .
         ELSE .
           CONTINUE .
         ENDIF.
       ELSE .
         lv_col_value1 = <gfs_field> .
       ENDIF.
       CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab lv_col_value1 INTO gs_paste .
     ELSE.
       EXIT .
     ENDIF.
    ENDDO.
    APPEND gs_paste TO gt_paste .
    DESCRIBE TABLE gt_paste LINES lv_lines .
    gs_country_lines-line_no = lv_lines .
    APPEND gs_country_lines TO gt_country_lines .

* Asset Level Data..
    IF gv_hier_level GT 1 .
      lv_cond_name2 = lv_cond_name1 .
      ASSIGN COMPONENT 2 OF STRUCTURE <gfs_country_line> TO <lfs_country> .
      CONCATENATE '''' <lfs_country> '''' INTO lv_country .
      CONCATENATE lv_cond_name2 'AND COUNTRY EQ' lv_country INTO lv_cond_name2 SEPARATED BY space .
      CLEAR lv_sr_no2 .
      LOOP AT <gfs_asset_data> ASSIGNING <gfs_asset_line> WHERE (lv_cond_name2) .
        CLEAR gs_paste .
        lv_sr_no2 = lv_sr_no2 + 1 .
        SHIFT lv_sr_no2 LEFT DELETING LEADING space .
        CONCATENATE lv_sr_no '.' lv_sr_no2 INTO lv_col_value1 .
        CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab lv_col_value1 INTO gs_paste .
        IF gv_hier_level GT 2.
          CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab INTO gs_paste .
        ENDIF.
        DO .
         lv_index1 = sy-index .
         ASSIGN COMPONENT lv_index1 OF STRUCTURE <gfs_asset_line> TO <gfs_field> .
         IF sy-subrc IS INITIAL.
           IF lv_index1 EQ 1 .
             CONTINUE .
           ELSEIF lv_index1 EQ 2.
             lv_col_value1 = '' .
           ELSEIF lv_index1 EQ 3 .
            READ TABLE gt_oiu_pr_dn INTO gs_oiu_pr_dn WITH KEY dn_no = <gfs_field> BINARY SEARCH .
            IF sy-subrc IS INITIAL.
             lv_col_value1 = gs_oiu_pr_dn-dn_de .
            ENDIF.
           ELSEIF lv_index1 EQ 4 .
             IF gv_hier_level GT 2.
               lv_col_value1 = '' .
             ELSE .
               CONTINUE .
             ENDIF.
           ELSE .
             lv_col_value1 = <gfs_field> .
           ENDIF.
           CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab lv_col_value1 INTO gs_paste .
         ELSE.
           EXIT .
         ENDIF.
        ENDDO.
        APPEND gs_paste TO gt_paste .
* Block Level Data..
        IF gv_hier_level GT 2 .
          lv_cond_name3 = lv_cond_name2 .
          ASSIGN COMPONENT 3 OF STRUCTURE <gfs_asset_line> TO <lfs_asset> .
          CONCATENATE '''' <lfs_asset> '''' INTO lv_asset .
          CONCATENATE lv_cond_name3 'AND ASSET EQ' lv_asset INTO lv_cond_name3 SEPARATED BY space .

          CLEAR lv_sr_no3 .
          LOOP AT <gfs_block_data> ASSIGNING <gfs_block_line> WHERE (lv_cond_name3) .
            CLEAR gs_paste .
            lv_sr_no3 = lv_sr_no3 + 1 .
            SHIFT lv_sr_no3 LEFT DELETING LEADING space .
            CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab cl_abap_char_utilities=>horizontal_tab lv_sr_no '.' lv_sr_no2 '.' lv_sr_no3 INTO lv_col_value1 .
            gs_paste = lv_col_value1 .
            DO .
             lv_index1 = sy-index .
             ASSIGN COMPONENT lv_index1 OF STRUCTURE <gfs_block_line> TO <gfs_field> .
             IF sy-subrc IS INITIAL.
               IF lv_index1 EQ 1 .
                 CONTINUE .
               ELSEIF lv_index1 EQ 2.
                 lv_col_value1 = '' .
               ELSEIF lv_index1 EQ 3 .
                 lv_col_value1 = ''.
               ELSEIF lv_index1 EQ 4 .
                 READ TABLE gt_oiu_pr_mp INTO gs_oiu_pr_mp WITH KEY mp_no = <gfs_field> BINARY SEARCH .
                 IF sy-subrc IS INITIAL .
                   lv_col_value1 = gs_oiu_pr_mp-mp_de .
                 ENDIF.
               ELSE .
                 lv_col_value1 = <gfs_field> .
               ENDIF.
               CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab lv_col_value1 INTO gs_paste .
             ELSE.
               EXIT .
             ENDIF.
            ENDDO.
            APPEND gs_paste TO gt_paste .
          ENDLOOP.
        ENDIF.
      ENDLOOP.
    ENDIF.
  ENDLOOP.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  PASTE_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM paste_data .
  DO 5 TIMES .
    CALL METHOD cl_gui_frontend_services=>clipboard_export
      IMPORTING
        data         = gt_paste
      CHANGING
        rc           = gv_rc
      EXCEPTIONS
        cntl_error   = 1
        error_no_gui = 2
        OTHERS       = 4.
    IF sy-subrc IS INITIAL AND gv_rc IS INITIAL.
      EXIT .
    ENDIF.
  ENDDO.
  DO 5 TIMES .
    CALL METHOD OF go_worksheet 'Paste'.
    IF sy-subrc IS INITIAL.
      EXIT.
    ENDIF.
  ENDDO.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  DISPLAY_PRODUCT_TOTAL
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_PRODUCT  text
*      -->P_PRODUCT_DESC  text
*----------------------------------------------------------------------*
FORM display_product_total  USING    p_product
                                     p_product_desc.

  DATA : lv_index      TYPE sy-tabix  ,
         lv_col_name   TYPE lvc_fname ,
         lv_col_value  TYPE char30    ,
         lv_col        TYPE sy-tabix  .

  CLEAR gs_paste.
  REFRESH gt_paste .
  lv_col_name = 'PRODUCT' .
  READ TABLE <gfs_total_data> ASSIGNING <gfs_total_line> WITH KEY  (lv_col_name) = p_product.
  CHECK sy-subrc IS INITIAL .
    DO .
     lv_index  = sy-index .
     ASSIGN COMPONENT lv_index  OF STRUCTURE <gfs_total_line> TO <gfs_field> .
     IF sy-subrc IS INITIAL.
       IF lv_index EQ 1 .
         DO  gv_hier_level - 1 TIMES.
           CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab INTO gs_paste .
         ENDDO.
         CONCATENATE 'Total' '-' p_product_desc INTO lv_col_value SEPARATED BY space.
       ELSEIF lv_index EQ 2.
         CONTINUE.
       ELSEIF lv_index EQ 3 .
         IF gv_hier_level GT 1.
           lv_col_value = '' .
         ELSE .
           CONTINUE .
         ENDIF.
       ELSEIF lv_index EQ 4 .
         IF gv_hier_level GT 2.
           lv_col_value = '' .
         ELSE .
           CONTINUE .
         ENDIF.
       ELSE .
         lv_col_value = <gfs_field> .
       ENDIF.
       CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab lv_col_value INTO gs_paste .
     ELSE.
       EXIT .
     ENDIF.
    ENDDO.
  APPEND gs_paste TO gt_paste .

  gv_row = gv_row + 1 .
  gv_s_row = gv_row .
  gv_s_col = 1 .
  gv_e_row = gv_s_row .
  gv_e_col = gv_s_col + gv_output_columns - 1.

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  PERFORM paste_data .

  lv_col = gv_output_columns - 5 + 1 .
  gv_s_col = gv_hier_level + 1 .
  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_output_columns  .
  PERFORM set_all_borders_range .

  PERFORM select_range USING gv_s_row 1 gv_e_row gv_e_col  .
  PERFORM set_thick_border USING 1 1 1 1 .

  PERFORM select_range USING gv_s_row 1 gv_e_row gv_output_columns  .
  PERFORM set_range_font  USING 11 1 .

  CASE p_product.
    WHEN c_prod_oil.
      PERFORM set_range_interior USING gv_header_oil_colour.
    WHEN c_prod_con.
      PERFORM set_range_interior USING gv_header_cond_colour.
    WHEN c_prod_lng.
      PERFORM set_range_interior USING gv_header_lng_colour.
    WHEN c_prod_gas.
      PERFORM set_range_interior USING gv_header_gas_colour.
    WHEN OTHERS.
  ENDCASE.

  IF p_product EQ c_prod_gas.
    gv_gas_end_row   = gv_row  .
  ENDIF.
  gv_row = gv_e_row + 1.
  PERFORM row_height USING gv_row 8 .

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  DISPLAY_GRAND_TOTAL
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM display_grand_total .
  DATA : lv_index      TYPE sy-tabix  ,
         lv_col_name   TYPE lvc_fname ,
         lv_col_value  TYPE char30    ,
         lv_col        TYPE sy-tabix  ,
         lv_unit       TYPE char50    .

  CLEAR gs_paste.
  REFRESH gt_paste .

  CASE abap_true.
    WHEN p_bb.
      lv_unit   = 'BOE' .
    WHEN p_bbd.
      lv_unit   = 'BOEPD' .
    WHEN p_tm.
      lv_unit   = 'TOE' .
    WHEN p_tmd.
      lv_unit   = 'TOEPD' .
    WHEN p_mb.
      lv_unit   = 'MMTOE' .
    WHEN p_bmd.
      lv_unit   = 'BOEPD' .
    WHEN OTHERS.
  ENDCASE.
  CONCATENATE 'Total -' lv_unit INTO lv_unit SEPARATED BY space .
  READ TABLE <gfs_grand_total_data> ASSIGNING <gfs_grand_total_line> INDEX 1 .
  IF sy-subrc IS INITIAL.
    DO .
     lv_index  = sy-index .
     ASSIGN COMPONENT lv_index  OF STRUCTURE <gfs_grand_total_line> TO <gfs_field> .
     IF sy-subrc IS INITIAL.
       IF lv_index EQ 1 .
         DO gv_hier_level - 1 TIMES.
           CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab INTO gs_paste .
         ENDDO.
         lv_col_value = lv_unit .
       ELSEIF lv_index EQ 2.
         CONTINUE.
       ELSEIF lv_index EQ 3 .
         IF gv_hier_level GT 1.
           lv_col_value = '' .
         ELSE .
           CONTINUE .
         ENDIF.
       ELSEIF lv_index EQ 4 .
         IF gv_hier_level GT 2.
           lv_col_value = '' .
         ELSE .
           CONTINUE .
         ENDIF.
       ELSE .
         lv_col_value = <gfs_field> .
       ENDIF.
       CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab lv_col_value INTO gs_paste .
     ELSE.
       EXIT .
     ENDIF.
    ENDDO.

  APPEND gs_paste TO gt_paste .

  gv_row = gv_row + 1 .
  gv_s_row = gv_row .
  gv_s_col = 1 .
  gv_e_row = gv_s_row .
  gv_e_col = gv_s_col + gv_output_columns - 1.

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  PERFORM paste_data .

  gv_row = gv_e_row .

  lv_col = gv_output_columns - 5 + 1 .
  PERFORM select_range USING gv_s_row lv_col gv_e_row gv_output_columns  .
  PERFORM set_all_borders_range .

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  PERFORM set_thick_border USING 1 1 1 1 .
  PERFORM set_range_interior USING gv_total_colour.

  PERFORM select_range USING gv_s_row 1 gv_e_row gv_output_columns  .
  PERFORM set_range_font  USING 11 1 .

  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  FORMAT_EXCEL
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM format_excel .
  PERFORM set_columns .
  PERFORM set_alignment .
  PERFORM set_number_format .
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  SET_COLUMNS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM set_columns .
  DATA : lv_year_col_start TYPE sy-tabix .
  CASE gv_hier_level.
    WHEN 1.
      PERFORM col_width USING 1 1 '6'  .
      PERFORM col_width USING 2 2 '18' .
    WHEN 2.
      PERFORM col_width USING 1 1 '3'  .
      PERFORM col_width USING 2 2 '4'  .
      PERFORM col_width USING 3 3 '3'  .
      PERFORM col_width USING 4 4 '30' .
    WHEN 3.
      PERFORM col_width USING 1 1 '3'  .
      PERFORM col_width USING 2 2 '4'  .
      PERFORM col_width USING 3 3 '5'  .
      PERFORM col_width USING 4 5 '3'  .
      PERFORM col_width USING 6 6 '30' .
    WHEN OTHERS.
  ENDCASE.

  PERFORM col_width USING gv_year_col_start gv_output_columns '15'  .
ENDFORM.
FORM col_width  USING p_col_start
                      p_col_end
                      p_width.
 PERFORM select_range USING 1 p_col_start 1 p_col_end  .
 SET PROPERTY OF go_range 'ColumnWidth' = p_width.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  SET_THICK_BORDER
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_1      text
*      -->P_1      text
*      -->P_1      text
*      -->P_1      text
*----------------------------------------------------------------------*
FORM set_thick_border  USING    p_left
                                p_right
                                p_top
                                p_bottom .
IF p_left EQ 1 .
  CALL METHOD OF go_range 'Borders' = go_border   EXPORTING #1 = '7' .
  SET PROPERTY OF go_border 'LineStyle' = '1'  .
  SET PROPERTY OF go_border 'Weight' = -4138  .
ENDIF.
IF p_right EQ 1 .
  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '10'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .
  SET PROPERTY OF go_border 'Weight' = -4138  .
ENDIF.
IF p_top EQ 1 .
  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '8'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .
  SET PROPERTY OF go_border 'Weight' = -4138  .
ENDIF.
IF p_bottom EQ 1 .
  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '9'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .
  SET PROPERTY OF go_border 'Weight' = -4138  .
ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  SET_ALL_BORDERS_RANGE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_1      text
*      -->P_1      text
*      -->P_1      text
*      -->P_1      text
*----------------------------------------------------------------------*
FORM set_all_borders_range  .
  CALL METHOD OF go_range 'Borders' = go_border   EXPORTING #1 = '7' .
  SET PROPERTY OF go_border 'LineStyle' = '1'  .

  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '8'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .

  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '9'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .

  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '10'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .

  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '11'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .

  CALL METHOD OF go_range 'Borders' = go_border  EXPORTING #1 = '12'.
  SET PROPERTY OF go_border 'LineStyle' = '1' .

ENDFORM.

*&---------------------------------------------------------------------*
*&      Form  ROW_HEIGHT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_7      text
*      -->P_15     text
*----------------------------------------------------------------------*
FORM row_height  USING  p_row
