*&---------------------------------------------------------------------*
*&      Form  PREPARE_DYNAMIC_TABLES
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM prepare_dynamic_tables .
 DATA : lv_index     TYPE sy-tabix  ,
        lv_col_name  TYPE lvc_fname .
 CLEAR gv_pos .
 REFRESH gt_dyn_fcat .

 PERFORM add_dyn_field USING 'PRODUCT'  'Product' 30 .
 PERFORM add_dyn_field USING 'COUNTRY'  'Country' 30 .
 PERFORM add_dyn_field USING 'ASSET'    'Asset'   30 .
 PERFORM add_dyn_field USING 'BLOCK'    'Block'   30 .

 DO 5 TIMES.
  lv_index = sy-index .
  lv_col_name = gv_gjahr_from + lv_index - 1.
  SHIFT lv_col_name LEFT DELETING LEADING space .
  PERFORM add_dyn_field USING lv_col_name lv_col_name   30 .
 ENDDO.

** Create a dynamic internal table with this structure.
  CALL METHOD cl_alv_table_create=>create_dynamic_table
  EXPORTING
*  i_style_table             = ‘X’
  it_fieldcatalog           = gt_dyn_fcat
  IMPORTING
  ep_table                  = gt_block_data
  EXCEPTIONS
  generate_subpool_dir_full = 1
  OTHERS                    = 2.
  IF sy-subrc NE 0.
   MESSAGE 'Unexpected Internal Error' TYPE 'E' .
  ELSE.
* Assign the new table to field symbol
    ASSIGN gt_block_data->* TO <gfs_block_data>.
  ENDIF.

  CALL METHOD cl_alv_table_create=>create_dynamic_table
  EXPORTING
*  i_style_table             = ‘X’
  it_fieldcatalog           = gt_dyn_fcat
  IMPORTING
  ep_table                  = gt_asset_data
  EXCEPTIONS
  generate_subpool_dir_full = 1
  OTHERS                    = 2.
  IF sy-subrc NE 0.
   MESSAGE 'Unexpected Internal Error' TYPE 'E' .
  ELSE.
* Assign the new table to field symbol
    ASSIGN gt_asset_data->* TO <gfs_asset_data>.
  ENDIF.

  CALL METHOD cl_alv_table_create=>create_dynamic_table
  EXPORTING
*  i_style_table             = ‘X’
  it_fieldcatalog           = gt_dyn_fcat
  IMPORTING
  ep_table                  = gt_country_data
  EXCEPTIONS
  generate_subpool_dir_full = 1
  OTHERS                    = 2.
  IF sy-subrc NE 0.
   MESSAGE 'Unexpected Internal Error' TYPE 'E' .
  ELSE.
* Assign the new table to field symbol
    ASSIGN gt_country_data->* TO <gfs_country_data>.
  ENDIF.

  CALL METHOD cl_alv_table_create=>create_dynamic_table
  EXPORTING
*  i_style_table             = ‘X’
  it_fieldcatalog           = gt_dyn_fcat
  IMPORTING
  ep_table                  = gt_total_data
  EXCEPTIONS
  generate_subpool_dir_full = 1
  OTHERS                    = 2.
  IF sy-subrc NE 0.
   MESSAGE 'Unexpected Internal Error' TYPE 'E' .
  ELSE.
* Assign the new table to field symbol
    ASSIGN gt_total_data->* TO <gfs_total_data>.
  ENDIF.

  CALL METHOD cl_alv_table_create=>create_dynamic_table
  EXPORTING
*  i_style_table             = ‘X’
  it_fieldcatalog           = gt_dyn_fcat
  IMPORTING
  ep_table                  = gt_grand_total_data
  EXCEPTIONS
  generate_subpool_dir_full = 1
  OTHERS                    = 2.
  IF sy-subrc NE 0.
   MESSAGE 'Unexpected Internal Error' TYPE 'E' .
  ELSE.
* Assign the new table to field symbol
    ASSIGN gt_grand_total_data->* TO <gfs_grand_total_data>.
  ENDIF.
ENDFORM.
