 	WHEN 'MCF'.
    lv_qty = p_zpra_t_mrec_prd-prod_vl_qty1 / '35.3'.
 	WHEN OTHERS.
 ENDCASE.

* Convert to display UoM
 CASE abap_true.
 	WHEN p_bb.
    p_zpra_t_mrec_prd-prod_vl_qty1 = lv_qty * 6290 .
 	WHEN p_bbd.
    p_zpra_t_mrec_prd-prod_vl_qty1 = lv_qty * 6290 .
 	WHEN p_tm.
    p_zpra_t_mrec_prd-prod_vl_qty1 = lv_qty * 1000 .
 	WHEN p_tmd.
    p_zpra_t_mrec_prd-prod_vl_qty1 = lv_qty * 1000 .
 	WHEN p_mb.
