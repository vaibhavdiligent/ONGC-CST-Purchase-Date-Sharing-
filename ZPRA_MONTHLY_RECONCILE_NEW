FORM add_gas_records_values .
  DATA : ls_zpra_t_prd_pi   TYPE zpra_t_prd_pi              .
  DATA : lv_cursor         TYPE sy-tabix,
         lv_qty            TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_month      TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_quarter    TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_half_year  TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_year       TYPE zpra_t_mrec_app-app_vl_qty,
         lv_found          TYPE c,
         lv_days           TYPE sy-tabix,
         lv_prd_start_date TYPE sy-datum,

         lv_qty2           TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_month2     TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_quarter2   TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_half_year2 TYPE zpra_t_mrec_app-app_vl_qty,
         lv_qty_year2      TYPE zpra_t_mrec_app-app_vl_qty.


  LOOP AT gt_zpra_c_prd_prof INTO gs_zpra_c_prd_prof WHERE product EQ c_prod_gas.
