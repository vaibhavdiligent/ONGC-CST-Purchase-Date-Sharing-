*&---------------------------------------------------------------------*
*&      Form  GET_TONS_VALUE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_GS_ZPRA_T_DLY_PRD  text
*      <--P_LV_TEMP_QTY  text
*----------------------------------------------------------------------*
FORM get_tons_value  USING    p_zpra_t_dly_prd TYPE zpra_t_dly_prd
                     CHANGING p_temp_qty.
  CLEAR : gs_zpra_t_mrec_prd ,
          p_temp_qty        .
  LOOP AT gt_zpra_t_mrec_prd INTO gs_zpra_t_mrec_prd WHERE product = p_zpra_t_dly_prd-product
                                                       AND asset   = p_zpra_t_dly_prd-asset
                                                       AND block   = p_zpra_t_dly_prd-block
                                                       AND prd_vl_type = p_zpra_t_dly_prd-prd_vl_type
                                                       AND prod_vl_qty1 IS NOT INITIAL .
    IF gs_zpra_t_mrec_prd-gjahr LT gv_current_gjahr OR "lt
       gs_zpra_t_mrec_prd-monat LE gv_monat .
      EXIT .
    ENDIF.
  ENDLOOP.
  IF sy-subrc IS INITIAL.
    p_temp_qty = p_zpra_t_dly_prd-prod_vl_qty1 / gs_zpra_t_mrec_prd-prod_vl_qty1 * gs_zpra_t_mrec_prd-prod_vl_qty2 .
  ENDIF.
ENDFORM.
