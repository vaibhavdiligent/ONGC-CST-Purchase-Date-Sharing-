*&      Form  F4_CNTRY
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM f4_cntry .
  TYPES : BEGIN OF ty_cntry ,
            land1 TYPE t005t-land1,
            landx TYPE t005t-landx,
          END OF   ty_cntry .

  DATA : lt_cntry TYPE STANDARD TABLE OF ty_cntry .
  DATA : ls_cntry TYPE                   ty_cntry .

  SELECT b~land1
         b~landx
    FROM zpro_c_projmast AS a
   INNER JOIN t005t AS b
      ON a~cntry_cd = b~land1
    INTO TABLE lt_cntry
   WHERE b~spras EQ sy-langu .

  SORT lt_cntry .
  DELETE ADJACENT DUPLICATES FROM lt_cntry .

  CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
    EXPORTING
      retfield        = 'LAND1'
      dynpprog        = sy-repid
      dynpnr          = sy-dynnr
      dynprofield     = 'S_CNTRY'
      value_org       = 'S'
    TABLES
      value_tab       = lt_cntry
    EXCEPTIONS
      parameter_error = 1
      no_values_found = 2
      OTHERS          = 3.
  IF sy-subrc EQ 0.
  ENDIF. " IF SY-SUBRC EQ 0

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  F4_PROJ
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM f4_proj .
  TYPES : BEGIN OF ty_proj ,
            proj_id   TYPE zpro_c_projmast-proj_id,
            proj_desc TYPE zpro_c_projmast-proj_desc,
          END OF   ty_proj .

  DATA : lt_proj TYPE STANDARD TABLE OF ty_proj .
  DATA : ls_proj TYPE                   ty_proj .

  SELECT proj_id
         proj_desc
    FROM zpro_c_projmast
    INTO TABLE lt_proj
   WHERE cntry_cd IN s_cntry[]
     AND proj_type IN s_p_type[] .

  SORT lt_proj .
  DELETE ADJACENT DUPLICATES FROM lt_proj .

  CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
    EXPORTING
      retfield        = 'PROJ_ID'
      dynpprog        = sy-repid
      dynpnr          = sy-dynnr
      dynprofield     = 'S_PROJ'
      value_org       = 'S'
    TABLES
      value_tab       = lt_proj
    EXCEPTIONS
      parameter_error = 1
      no_values_found = 2
      OTHERS          = 3.
  IF sy-subrc EQ 0.
  ENDIF. " IF SY-SUBRC EQ 0

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GET_YEAR_TEXT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM get_year_text .
  DATA: lv_next_year TYPE gjahr.

  IF p_gjahr IS NOT INITIAL.
    CLEAR: lv_next_year.
    lv_next_year = p_gjahr + 1.
    CONCATENATE: 'Fiscal Year' p_gjahr  'means FY'  p_gjahr '-' lv_next_year+2(2)
    INTO gv_year
    SEPARATED BY space.
  ELSE.
    CLEAR: gv_year.
  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  CHECK_GJAHR
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM check_gjahr .
  DATA : lv_gjahr TYPE zpra_t_mrec_prd-gjahr,
         lv_poper TYPE t009b-poper.
  SELECT SINGLE periv
           FROM t001
           INTO gv_periv
          WHERE bukrs EQ 'OVL' .

  CALL FUNCTION 'DATE_TO_PERIOD_CONVERT'
    EXPORTING
      i_date         = sy-datum
    " I_MONMIT       = 00
      i_periv        = gv_periv
    IMPORTING
      e_buper        = lv_poper
      e_gjahr        = lv_gjahr
    EXCEPTIONS
      input_false    = 01
      t009_notfound  = 02
      t009b_notfound = 03.

  IF sy-subrc <> 0.
    MESSAGE 'Error getting Period' TYPE 'E' .
  ENDIF.
  IF lv_gjahr EQ p_gjahr.
*    MESSAGE 'Current Fiscal Year can not be selected' TYPE 'E' .
  ELSEIF p_gjahr GT lv_gjahr.
    MESSAGE 'Future Fiscal Year can not be selected' TYPE 'E' .
  ENDIF.

ENDFORM.
