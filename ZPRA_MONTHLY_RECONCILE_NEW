*&      Form  GET_MONTH_DESC
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM get_month_desc .
  DATA lv_mnr TYPE t247-mnr .

  IF gt_t247 IS INITIAL.
    SELECT *
      FROM t247
      INTO TABLE gt_t247
     WHERE spras EQ sy-langu .
    SORT gt_t247 BY mnr .
  ENDIF.
  lv_mnr = gs_month_days-month + 3 .
  IF lv_mnr GT 12 .
    lv_mnr = lv_mnr - 12 .
  ENDIF.
  READ TABLE gt_t247 INTO gs_t247 WITH KEY mnr = lv_mnr BINARY SEARCH .
  IF sy-subrc IS INITIAL.
    gs_month_days-desc = gs_t247-ltx .
  ENDIF.

ENDFORM.
