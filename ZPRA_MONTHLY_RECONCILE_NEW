*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM add_drilling_values .
  DATA : lt_zops_wmonrep1 TYPE STANDARD TABLE OF zops_wmonrep,
         lt_zops_wmonrep2 TYPE STANDARD TABLE OF zops_wmonrep.
  DATA : lv_d_count TYPE                   sy-tabix,
         lv_e_count TYPE                   sy-tabix.

  lt_zops_wmonrep1 = gt_zops_wmonrep .
  DELETE lt_zops_wmonrep1 WHERE repdate LT gs_month_days-s_date
                             OR repdate GT gs_month_days-e_date .
  SORT lt_zops_wmonrep1 BY uwi .
  DELETE ADJACENT DUPLICATES FROM lt_zops_wmonrep1 COMPARING uwi .
  lt_zops_wmonrep2 = lt_zops_wmonrep1 .

  DELETE lt_zops_wmonrep1 WHERE wellcat NE 'DEVELOPMENT' .
  DESCRIBE TABLE lt_zops_wmonrep1 LINES lv_d_count       .
  DELETE lt_zops_wmonrep1 WHERE wellcat NE 'EXPLORATORY' .
  DESCRIBE TABLE lt_zops_wmonrep2 LINES lv_e_count       .

  ASSIGN COMPONENT 'D_WELLS' OF STRUCTURE <gfs_month_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_d_count.
  ENDIF.
  ASSIGN COMPONENT 'E_WELLS' OF STRUCTURE <gfs_month_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_e_count.
  ENDIF.

  ASSIGN COMPONENT 'D_WELLS' OF STRUCTURE <gfs_quarter_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_d_count.
  ENDIF.
  ASSIGN COMPONENT 'E_WELLS' OF STRUCTURE <gfs_quarter_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_e_count.
  ENDIF.

  ASSIGN COMPONENT 'D_WELLS' OF STRUCTURE <gfs_half_year_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_d_count.
  ENDIF.
  ASSIGN COMPONENT 'E_WELLS' OF STRUCTURE <gfs_half_year_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_e_count.
  ENDIF.

  ASSIGN COMPONENT 'D_WELLS' OF STRUCTURE <gfs_year_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_d_count.
  ENDIF.
  ASSIGN COMPONENT 'E_WELLS' OF STRUCTURE <gfs_year_line> TO <gfs_field> .
  IF sy-subrc IS INITIAL.
    <gfs_field> = <gfs_field> + lv_e_count.
  ENDIF.
ENDFORM.
