*&      Form  DISPLAY_DATA_LINES
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM display_data_lines .
  DATA : lv_half_year_index TYPE sy-tabix,
         lv_quarter_index   TYPE sy-tabix,
         lv_month_index     TYPE sy-tabix,
         lv_index           TYPE sy-index.
  gv_data_start_row = gv_row + 1 .
  DO 2 TIMES. "Half_yearly
    lv_half_year_index = sy-index .
    DO 2 TIMES. "Quarterly
      lv_index = sy-index .
      lv_quarter_index = ( lv_half_year_index - 1 ) * 2 + lv_index .
      PERFORM display_monthly_data USING lv_quarter_index.
      PERFORM display_quarterly_data USING lv_quarter_index .
    ENDDO.
    PERFORM display_half_yearly_data USING lv_half_year_index .
  ENDDO.
  PERFORM display_yearly_data .
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  DISPLAY_MONTHLY_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM display_monthly_data USING p_quarter.
  DATA : lv_month_index TYPE sy-tabix,
         lv_field_index TYPE sy-tabix,
         lv_index       TYPE sy-tabix,
         lv_lines       TYPE sy-tabix.

  CLEAR gs_paste .
  REFRESH gt_paste .
  DO 3 TIMES .
    lv_index = sy-index .
    lv_month_index = ( p_quarter - 1 ) * 3 + lv_index .
    READ TABLE <gfs_month_data> ASSIGNING <gfs_month_line> INDEX lv_month_index.
    IF sy-subrc IS INITIAL.
      DO .
        lv_field_index = sy-index .
        ASSIGN COMPONENT lv_field_index OF STRUCTURE <gfs_month_line> TO <gfs_field> .
        IF sy-subrc IS INITIAL.
          IF lv_field_index EQ 1.
            gs_paste = <gfs_field> .
          ELSE.
            CONCATENATE gs_paste cl_abap_char_utilities=>horizontal_tab <gfs_field> INTO gs_paste .
          ENDIF.
        ELSE.
          EXIT .
        ENDIF.
      ENDDO.
    ENDIF.
    APPEND gs_paste TO gt_paste .
  ENDDO .

  DESCRIBE TABLE gt_paste LINES lv_lines .
  CHECK lv_lines IS NOT INITIAL .

  gv_row = gv_row + 1 .

  gv_s_row = gv_row .
  gv_s_col = 1 .
  gv_e_row = gv_s_row + lv_lines - 1 .
  gv_e_col = gv_s_col + gv_output_columns - 1.

  PERFORM select_range USING gv_s_row gv_s_col gv_e_row gv_e_col  .
  PERFORM paste_data .
  PERFORM set_all_borders_range .

  gv_row = gv_row + 2 .
ENDFORM.
