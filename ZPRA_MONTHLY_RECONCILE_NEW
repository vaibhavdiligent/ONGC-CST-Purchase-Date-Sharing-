FORM preprocess_gas_records .
  DATA : lt_zpra_t_dly_prd  TYPE STANDARD TABLE OF zpra_t_dly_prd  .
  DATA : ls_zpra_t_dly_prd   TYPE                  zpra_t_dly_prd  .
  FIELD-SYMBOLS : <fs_dly_prd> TYPE zpra_t_dly_prd  .
  DATA : lv_index TYPE sy-tabix .

  lt_zpra_t_dly_prd  = gt_zpra_t_dly_prd .
  SORT  lt_zpra_t_dly_prd BY production_date product asset block prd_vl_type .

  DELETE gt_zpra_t_dly_prd  WHERE product EQ c_prod_gas .
  DELETE lt_zpra_t_dly_prd  WHERE product NE c_prod_gas .

  IF lt_zpra_t_dly_prd IS NOT INITIAL.
    LOOP AT lt_zpra_t_dly_prd INTO ls_zpra_t_dly_prd .
      lv_index = sy-tabix .
      IF lv_index EQ 1 OR
        <fs_dly_prd>-production_date NE ls_zpra_t_dly_prd-production_date  OR
        <fs_dly_prd>-product         NE ls_zpra_t_dly_prd-product          OR
        <fs_dly_prd>-asset           NE ls_zpra_t_dly_prd-asset            OR
        <fs_dly_prd>-block           NE ls_zpra_t_dly_prd-block .

        APPEND INITIAL LINE TO gt_zpra_t_dly_prd ASSIGNING <fs_dly_prd> .
        <fs_dly_prd>-mandt           = ls_zpra_t_dly_prd-mandt .
        <fs_dly_prd>-production_date = ls_zpra_t_dly_prd-production_date .
        <fs_dly_prd>-product         = ls_zpra_t_dly_prd-product .
        <fs_dly_prd>-asset           = ls_zpra_t_dly_prd-asset .
        <fs_dly_prd>-block           = ls_zpra_t_dly_prd-block .
        <fs_dly_prd>-prod_vl_uom1    = ls_zpra_t_dly_prd-prod_vl_uom1 .
        <fs_dly_prd>-prd_vl_type     = 'NET_PROD' .
      ENDIF.
      PERFORM convert_gas_units CHANGING ls_zpra_t_dly_prd.
      IF ls_zpra_t_dly_prd-prd_vl_type EQ 'GAS_INJ' .
        ls_zpra_t_dly_prd-prod_vl_qty1 = ls_zpra_t_dly_prd-prod_vl_qty1 * -1 .
      ENDIF.
      <fs_dly_prd>-prod_vl_qty1    = <fs_dly_prd>-prod_vl_qty1 + ls_zpra_t_dly_prd-prod_vl_qty1 .
    ENDLOOP.
  ENDIF.

  SORT  gt_zpra_t_dly_prd BY product asset block production_date.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  CONVERT_GAS_UNITS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      <--P_ZPRA_T_DLY_PRD  text
*----------------------------------------------------------------------*
FORM convert_gas_units  CHANGING p_zpra_t_dly_prd TYPE zpra_t_dly_prd.
  DATA : lv_qty TYPE char50 .
* First Convert to MCM

  CASE p_zpra_t_dly_prd-prod_vl_uom1 .
    WHEN 'MCM'.
      lv_qty = p_zpra_t_dly_prd-prod_vl_qty1.
    WHEN 'M3'.
      lv_qty = p_zpra_t_dly_prd-prod_vl_qty1 / 1000000 .
    WHEN 'MCF'.
      lv_qty = p_zpra_t_dly_prd-prod_vl_qty1 / '35.3'.
    WHEN OTHERS.
  ENDCASE.

  p_zpra_t_dly_prd-prod_vl_qty1 = lv_qty .
ENDFORM.

*&---------------------------------------------------------------------*
*&      Form  GET_PERIODS_DAYS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM get_periods_days .
  DATA : lv_monat1      TYPE zpra_t_mrec_prd-monat,
         lv_monat2      TYPE zpra_t_mrec_prd-monat,
         lv_begin_date1 TYPE sy-datum,
         lv_begin_date2 TYPE sy-datum,
         lv_end_date1   TYPE sy-datum,
         lv_end_date2   TYPE sy-datum,
         lv_count       TYPE c.

  REFRESH : gt_month_days     ,
            gt_quarter_days   ,
            gt_half_year_days .
  lv_monat1 = 1 .
  DO 12 TIMES.
    gs_month_days-month = sy-index .
    PERFORM get_month_begin_end_dates USING gv_current_gjahr lv_monat1 CHANGING lv_begin_date1 lv_end_date1 .
    gs_month_days-days = lv_end_date1 - lv_begin_date1 + 1 .
    gs_month_days-s_date = lv_begin_date1 .
    gs_month_days-e_date = lv_end_date1 .
    PERFORM get_month_desc .
    APPEND gs_month_days TO gt_month_days .
    lv_monat1 = lv_monat1 + 1 .
  ENDDO.

  lv_monat1 = 1 .
  DO 4 TIMES.
    gs_quarter_days-quarter = sy-index .
    lv_monat2 = lv_monat1 + 2 .
    PERFORM get_month_begin_end_dates USING gv_current_gjahr lv_monat1 CHANGING lv_begin_date1 lv_end_date1 .
    PERFORM get_month_begin_end_dates USING gv_current_gjahr lv_monat2 CHANGING lv_begin_date2 lv_end_date2 .
    gs_quarter_days-days = lv_end_date2 - lv_begin_date1 + 1 .
    gs_quarter_days-s_date = lv_begin_date1 .
    gs_quarter_days-e_date = lv_end_date2 .
    lv_count = gs_quarter_days-quarter .
    CONCATENATE 'Total Q' lv_count INTO gs_quarter_days-desc  .
    APPEND gs_quarter_days TO gt_quarter_days .
    lv_monat1 = lv_monat1 + 3 .
  ENDDO.

  lv_monat1 = 1 .
  DO 2 TIMES.
    gs_half_year_days-half_year     = sy-index .
    lv_monat2 = lv_monat1 + 5 .
    PERFORM get_month_begin_end_dates USING gv_current_gjahr lv_monat1 CHANGING lv_begin_date1 lv_end_date1 .
    PERFORM get_month_begin_end_dates USING gv_current_gjahr lv_monat2 CHANGING lv_begin_date2 lv_end_date2 .
    gs_half_year_days-days = lv_end_date2 - lv_begin_date1 + 1 .
    gs_half_year_days-s_date = lv_begin_date1 .
    gs_half_year_days-e_date = lv_end_date2 .
    lv_count = gs_half_year_days-half_year .
    CONCATENATE 'H' lv_count INTO gs_half_year_days-desc .
    APPEND gs_half_year_days TO gt_half_year_days .
    lv_monat1 = lv_monat1 + 6 .
  ENDDO.

  gv_current_gjahr_days = gv_year_end_date - gv_year_start_date + 1 .
  CONCATENATE gv_current_gjahr '-' gv_next_gjahr+2(2) INTO gs_year_days-desc  .
  gs_year_days-days   = gv_current_gjahr_days .
  gs_year_days-s_date = gv_year_start_date    .
  gs_year_days-e_date = gv_year_end_date      .
  APPEND gs_year_days TO gt_year_days .

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GET_MONTH_BEGIN_END_DATES
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_GV_CURRENT_GJAHR  text
*      -->P_LV_MONAT  text
*      <--P_LV_BEGIN_DATE  text
*      <--P_LV_END_DATE  text
*----------------------------------------------------------------------*
FORM get_month_begin_end_dates  USING    p_gjahr
                                         p_monat
                                CHANGING p_begin_date
                                         p_end_date.

  DATA : lv_poper TYPE t009b-poper .
  lv_poper = p_monat .

  CALL FUNCTION 'FIRST_DAY_IN_PERIOD_GET'
    EXPORTING
      i_gjahr        = p_gjahr
*     I_MONMIT       = 00
      i_periv        = gv_periv
      i_poper        = lv_poper
    IMPORTING
      e_date         = p_begin_date
    EXCEPTIONS
      input_false    = 1
      t009_notfound  = 2
      t009b_notfound = 3
      OTHERS         = 4.
  IF sy-subrc <> 0.
    MESSAGE 'Internal Error' TYPE 'E' .
  ENDIF.

  CALL FUNCTION 'LAST_DAY_IN_PERIOD_GET'
    EXPORTING
      i_gjahr        = p_gjahr
*     I_MONMIT       = 00
      i_periv        = gv_periv
      i_poper        = lv_poper
    IMPORTING
      e_date         = p_end_date
    EXCEPTIONS
      input_false    = 1
      t009_notfound  = 2
      t009b_notfound = 3
      OTHERS         = 4.
  IF sy-subrc <> 0.
    MESSAGE 'Internal Error' TYPE 'E' .
  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  FILL_DYNAMIC_TABLES
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM fill_dynamic_tables .

  READ TABLE gt_year_days INTO gs_year_days INDEX 1 .
  IF sy-subrc IS INITIAL .
    APPEND INITIAL LINE TO <gfs_year_data> ASSIGNING <gfs_year_line> .
    ASSIGN COMPONENT 'MONTH' OF STRUCTURE <gfs_year_line> TO <gfs_field> .
    IF sy-subrc IS INITIAL.
      <gfs_field> = gs_year_days-desc .
    ENDIF.
    ASSIGN COMPONENT 'DAYS' OF STRUCTURE <gfs_year_line> TO <gfs_field> .
    IF sy-subrc IS INITIAL.
      <gfs_field> = gs_year_days-days .
    ENDIF.
  ENDIF.

  LOOP AT gt_month_days INTO gs_month_days.
    gv_monat = sy-tabix .
    APPEND INITIAL LINE TO <gfs_month_data> ASSIGNING <gfs_month_line> .
    ASSIGN COMPONENT 'MONTH' OF STRUCTURE <gfs_month_line> TO <gfs_field> .
    IF sy-subrc IS INITIAL.
      <gfs_field> = gs_month_days-desc .
    ENDIF.
    ASSIGN COMPONENT 'DAYS' OF STRUCTURE <gfs_month_line> TO <gfs_field> .
    IF sy-subrc IS INITIAL.
      <gfs_field> = gs_month_days-days .
    ENDIF.

    READ TABLE gt_quarter_days INTO gs_quarter_days WITH KEY s_date = gs_month_days-s_date BINARY SEARCH .
    IF sy-subrc IS INITIAL.
      APPEND INITIAL LINE TO <gfs_quarter_data> ASSIGNING <gfs_quarter_line> .
      ASSIGN COMPONENT 'MONTH' OF STRUCTURE <gfs_quarter_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL.
        <gfs_field> = gs_quarter_days-desc .
      ENDIF.
      ASSIGN COMPONENT 'DAYS' OF STRUCTURE <gfs_quarter_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL.
        <gfs_field> = gs_quarter_days-days .
      ENDIF.
    ENDIF.
    READ TABLE gt_half_year_days INTO gs_half_year_days WITH KEY s_date = gs_month_days-s_date BINARY SEARCH .
    IF sy-subrc IS INITIAL.
      APPEND INITIAL LINE TO <gfs_half_year_data> ASSIGNING <gfs_half_year_line> .
      ASSIGN COMPONENT 'MONTH' OF STRUCTURE <gfs_half_year_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL.
        <gfs_field> = gs_half_year_days-desc .
      ENDIF.
      ASSIGN COMPONENT 'DAYS' OF STRUCTURE <gfs_half_year_line> TO <gfs_field> .
      IF sy-subrc IS INITIAL.
        <gfs_field> = gs_half_year_days-days .
      ENDIF.
    ENDIF.
    PERFORM add_gas_records_values .
    PERFORM add_non_gas_records_values .
*    PERFORM add_survey_values .
*    PERFORM add_drilling_values .
  ENDLOOP.
  PERFORM get_calculated_values .
ENDFORM.
