   WHERE asset IN r_asset[]
     AND product IN r_product[].
  CHECK gt_zpra_c_prd_prof IS NOT INITIAL .

  SORT gt_zpra_c_prd_prof BY product asset block ASCENDING valid_from DESCENDING.
  DELETE ADJACENT DUPLICATES FROM gt_zpra_c_prd_prof COMPARING product asset block .
  PERFORM remove_expired_blocks TABLES gt_zpra_c_prd_prof USING  gv_year_start_date gv_year_end_date .

  CHECK gt_zpra_c_prd_prof IS NOT INITIAL .

**  SELECT *
**    FROM zpra_t_dly_prd
**    INTO TABLE gt_zpra_t_dly_prd
**     FOR ALL ENTRIES IN gt_zpra_c_prd_prof
**   WHERE production_date  GE gv_year_start_date
**     AND production_date  LE gv_year_end_date
**     AND asset   EQ gt_zpra_c_prd_prof-asset
**     AND block   EQ gt_zpra_c_prd_prof-block
**     AND product EQ gt_zpra_c_prd_prof-product
**     AND prd_vl_type IN r_prd_vl_type[] .
**
**  PERFORM populate_no_data_entries TABLES gt_zpra_t_dly_prd USING gv_year_start_date gv_year_end_date .
**
**  SORT  gt_zpra_t_dly_prd BY  product asset block production_date.

  SELECT *
    FROM zpra_t_dly_rprd
    INTO TABLE gt_zpra_t_dly_rprd
     FOR ALL ENTRIES IN gt_zpra_c_prd_prof
   WHERE production_date  GE gv_year_start_date
     AND production_date  LE gv_year_end_date
     AND asset   EQ gt_zpra_c_prd_prof-asset
     AND block   EQ gt_zpra_c_prd_prof-block
     AND product EQ gt_zpra_c_prd_prof-product
*     AND prd_vl_type IN r_prd_vl_type[] .
     AND prd_vl_type EQ 'NET_PROD' .
  SORT  gt_zpra_t_dly_rprd BY  product asset block production_date.

  lv_gjahr = gv_current_gjahr - 2 .
  SELECT *
    FROM zpra_t_mrec_prd
    INTO TABLE gt_zpra_t_mrec_prd
     FOR ALL ENTRIES IN gt_zpra_c_prd_prof
   WHERE gjahr   GE lv_gjahr
