FORM get_pra_data .
  DATA lv_gjahr TYPE zpra_t_mrec_prd-gjahr .
  REFRESH :gt_zpra_c_prd_prof,gt_zpra_t_dly_rprd.
  CHECK r_asset[] IS NOT INITIAL .

  SELECT *
    FROM zpra_c_prd_prof
