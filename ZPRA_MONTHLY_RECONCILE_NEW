FORM fetch_data .
  break abapuser02.

  DATA : lv_gjahr TYPE zpra_t_mrec_prd-gjahr .
  DATA : lv_no_of_days(2) TYPE c.
  gv_current_gjahr = p_gjahr .
  gv_next_gjahr    = p_gjahr + 1 .

  CALL FUNCTION 'FIRST_AND_LAST_DAY_IN_YEAR_GET'
    EXPORTING
      i_gjahr        = gv_current_gjahr
      i_periv        = gv_periv
    IMPORTING
      e_first_day    = gv_year_start_date
      e_last_day     = gv_year_end_date
    EXCEPTIONS
      input_false    = 1
      t009_notfound  = 2
      t009b_notfound = 3
      OTHERS         = 4.
  IF sy-subrc <> 0.
    MESSAGE 'Unexpected Internal Error' TYPE 'E'.
  ENDIF.
  CLEAR flag.
  IF p_gjahr IS NOT INITIAL AND  s_cntry  IS INITIAL AND s_p_type  IS INITIAL AND s_proj IS INITIAL .
    flag = 'X'.
  ENDIF.
* IF p_peri IS NOT INITIAL.
*  IF p_peri EQ '11'.
*    lv_no_of_days = '28'.
*  ELSEIF p_peri EQ '01' OR p_peri EQ '03' OR p_peri EQ '06' OR p_peri EQ '08'.
*    lv_no_of_days = '30'.
*  ELSE.
*    lv_no_of_days = '31'.
*  ENDIF.
* ENDIF.
*
* IF p_peri GT '09'.
*   CLEAR gv_year_end_date.
*   CONCATENATE gv_next_gjahr p_peri lv_no_of_days INTO gv_year_end_date.
* ELSEIF p_peri IS NOT INITIAL.
*    CLEAR gv_year_end_date.
*   CONCATENATE gv_current_gjahr p_peri lv_no_of_days INTO gv_year_end_date.
* ENDIF.

  PERFORM get_periods_days.

  PERFORM add_product_range USING  :  c_prod_oil ,
                                      c_prod_con ,
*                                    c_prod_lng ,
                                      c_prod_gas .
  PERFORM add_vl_type_range USING  :  'NET_PROD'  ,
                                      'GROSS_PROD',
                                      'GAS_INJ'   .

*-----------------------" Changes begins by Aparna "--------------------------------*

  IF flag = 'X'.

    SELECT *
      FROM zpro_c_projmast
      INTO TABLE gt_zpro_c_projmast2
     WHERE cntry_cd  IN s_cntry[]
       AND proj_type IN s_p_type[]
       AND proj_id   IN ( 'AZE_ACG' , 'BRA_BC1' , 'COL_MEC' , 'COL_CPO' , 'MMR_BA1' , 'MMR_BA3',  'RUS_IEC' ,
                          'RUS_SK1' , 'RUS_VAN' , 'SSU_GPO' , 'SSU_SPO' , 'UAE_LZC' ,  'VEN_CAR' , 'VEN_SAN' , 'VNM_B06' ). " 'MMR_BA3',
    IF sy-subrc IS NOT INITIAL.
      MESSAGE 'No data found for the selection' TYPE 'E' .
    ENDIF.

    REFRESH:gt_zpro_c_projmast[].
    gt_zpro_c_projmast[] = gt_zpro_c_projmast2[].
    DELETE gt_zpro_c_projmast WHERE proj_id = 'MMR_BA3'.

***    SELECT *
***    FROM zpro_c_projmast
***    INTO TABLE gt_zpro_c_projmast2
***    WHERE cntry_cd  IN s_cntry[]
***    AND proj_type IN s_p_type[]
***    AND proj_id = 'MMR_BA3'.

  ELSE.
    SELECT *
      FROM zpro_c_projmast
      INTO TABLE gt_zpro_c_projmast
     WHERE cntry_cd  IN s_cntry[]
       AND proj_type IN s_p_type[]
       AND proj_id   IN s_proj[] .
    IF sy-subrc IS NOT INITIAL.
      MESSAGE 'No data found for the selection' TYPE 'E' .
    ENDIF.
  ENDIF.
  IF flag = 'X'.
    DATA(gt_zpro_c_projmast_temp) = gt_zpro_c_projmast[].
    SORT gt_zpro_c_projmast_temp DESCENDING BY proj_id.
    TRY.
        DATA(wa_zpro_c_projmast_temp) = gt_zpro_c_projmast_temp[ 1 ].
        wa_zpro_c_projmast_temp-proj_id = 'FIN'.
        wa_zpro_c_projmast_temp-proj_desc = 'Final'.
        APPEND wa_zpro_c_projmast_temp TO gt_zpro_c_projmast.
        CLEAR  wa_zpro_c_projmast_temp.
      CATCH cx_sy_itab_line_not_found.
